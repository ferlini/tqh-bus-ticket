logging:
  level:
    com.tqh.bus.ticket: INFO

tqh:
  base-url: https://your-api-domain.com
  auth-token: "your-auth-token-here"
  log-file-path: /path/to/prod/logs/ticket.log

openclaw:
  webhook:
    url: http://127.0.0.1:18789/hooks/wake
    token: "your-openclaw-token-here"
    channel: "your-openclaw-channel-here"
