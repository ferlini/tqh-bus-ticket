# cron-watch-next-week.sh 使用的 OpenClaw Webhook 配置。
# 部署到服务器后复制为 ~/tqh-bus-ticket/.env 并填入真实值。

# OpenClaw 网关地址
OPENCLAW_URL="http://127.0.0.1:18789/hooks/wake"

# OpenClaw 网关 Bearer Token
OPENCLAW_TOKEN="your-token-here"

# 「开始监控」通知的目标 channel（用户微信，与应用内的有票通知 channel 区分）
OPENCLAW_START_CHANNEL="openclaw-weixin xxxxxxxx@im.wechat"
